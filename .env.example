# Call My Agent Hackathon — API keys
# Copy to .env and fill in only what you need for your build.
# .env is in .gitignore; never commit real keys.

# -----------------------------------------------------------------------------
# Anthropic (LLM brain — default for voice loop)
# Console: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Google Gemini (alternative LLM brain — free hackathon credits)
# Get a key at https://aistudio.google.com/apikey
# SDK: `uv add google-genai` → `from google import genai`
# Docs: https://ai.google.dev/gemini-api/docs
# `gemini-2.5-flash-lite` is the tightest-TTFT option for voice; promote to
# `gemini-2.5-flash` if the tool-call loop needs more reasoning headroom.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# `flash-lite` measured at ~340ms median TTFT (thinking disabled) — well under
# the 1.5s voice budget. `flash` is ~1.5s with thinking on, ~460ms with it off.
# When wiring server.py, always pass thinking_budget=0 for voice turns.
GEMINI_MODEL=gemini-2.5-flash-lite
# Which provider the voice loop uses. One of: "anthropic", "gemini".
LLM_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# AgentPhone — inbound voice (webhook mode) only. SMS is intentionally out of
# scope for this build; see SPEC.md → "Not in scope".
# Sign up via POST /v0/agent/sign-up then POST /v0/agent/verify
# Docs: https://docs.agentphone.ai
# -----------------------------------------------------------------------------
AGENTPHONE_API_KEY=sk_live_
# Returned by POST /v1/webhooks after you register your webhook URL.
AGENTPHONE_WEBHOOK_SECRET=whsec_
# Returned by POST /v1/numbers or GET /v1/numbers.
AGENTPHONE_NUMBER_ID=
# E.164 number provisioned for the agent. Not used as an SMS sender (no SMS in
# scope). Useful for displaying the dial-in number in demo notes.
AGENTPHONE_NUMBER=
# Optional saved setup outputs. setup_agent.py can print these after creation.
AGENTPHONE_AGENT_ID=
AGENTPHONE_VOICE_ID=
# Public HTTPS base URL used when registering AgentPhone webhooks.
PUBLIC_WEBHOOK_BASE_URL=

# -----------------------------------------------------------------------------
# Moss — real-time semantic search
# Keys from your Moss project portal.
# Docs: https://docs.moss.dev
# JailCall uses Moss for initial attorney routing (sub-10 ms over the
# pre-indexed Bay Area roster). Populate the index by running
# `uv run python -m jailcall.build_index` against `law_firms/`.
# -----------------------------------------------------------------------------
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=jailcall-lawyers

# -----------------------------------------------------------------------------
# Supermemory — persistent memory + user profiles
# Docs: https://supermemory.ai/docs
# -----------------------------------------------------------------------------
SUPERMEMORY_API_KEY=sm_

# -----------------------------------------------------------------------------
# Browser Use — agent web automation
# Get a key at https://cloud.browser-use.com/settings
# Docs: https://docs.browser-use.com
# -----------------------------------------------------------------------------
BROWSER_USE_API_KEY=bu_

# -----------------------------------------------------------------------------
# AgentMail — email inbox API for agents
# Console: https://console.agentmail.to
# Docs: https://docs.agentmail.to
# -----------------------------------------------------------------------------
AGENTMAIL_API_KEY=
AGENTMAIL_DISPATCH_INBOX=sb38318@agentmail.to

# -----------------------------------------------------------------------------
# Stripe Agent Toolkit — agentic payments
# Use a RESTRICTED key (rk_*), not a full sk_*, to limit blast radius.
# Dashboard → Developers → API keys → Restricted keys
# Docs: https://docs.stripe.com/agents
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=rk_

# -----------------------------------------------------------------------------
# Sponge — autonomous wallets + agent payment gateway
# Ask the Sponge booth on-site for a sandbox key.
# Site: https://paysponge.com
# -----------------------------------------------------------------------------
SPONGE_API_KEY=

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
PORT=5321
LOG_LEVEL=INFO
