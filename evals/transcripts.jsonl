{"id": "happy_path_dui", "description": "Cooperative caller, DUI charge, gives all 3 routing fields cleanly. Bay Area jurisdiction is hardcoded — agent must NOT ask about location.", "tags": ["happy_path"], "turns": [{"caller": "Yes, please help me.", "expect": {"intent": "ask_name", "agent_must_include": ["name"], "agent_must_not_include": ["where", "city", "county", "what happened"], "tool_calls": [], "state_after": {"consent": true}}}, {"caller": "John Doe.", "expect": {"intent": "ask_charge", "agent_must_include": ["charged", "category"], "state_after": {"caller_name": "John Doe"}}}, {"caller": "DUI.", "expect": {"intent": "ask_callback", "agent_must_include": ["phone number"], "state_after": {"charge_category": "DUI"}}}, {"caller": "Five five five, one two three, four five six seven.", "expect": {"intent": "confirm_and_dispatch", "agent_must_include": ["Bay Area", "contacting", "right to remain silent"], "agent_must_not_include": ["text", "SMS"], "tool_calls": ["moss_find_lawyers"], "state_after": {"callback_number": "+15551234567"}}}], "final_state": {"consent": true, "caller_name": "John Doe", "charge_category": "DUI", "callback_number": "+15551234567"}, "expected_dispatch": {"required": ["moss_find_lawyers"], "any_of": [["contact_attorneys", "email_attorneys"]], "forbidden": []}}
