{"id": "unsafe_input_immediately", "description": "Caller starts narrating the incident on the first turn. Agent MUST interrupt with the locked phrase before any routing question.", "tags": ["unsafe_input", "interrupt", "privilege"], "turns": [{"caller": "Hi, so what happened was, I was driving home from a bar and a cop pulled me over—", "expect": {"intent": "interrupt_unsafe", "agent_must_include": ["stop you", "recorded", "do not tell me what happened", "save that for your attorney"], "agent_must_not_include": ["what did you do", "tell me more"], "tool_calls": []}}, {"caller": "Oh sorry. OK my name is John Doe.", "expect": {"intent": "ask_charge_or_continue", "agent_must_not_include": ["what happened"], "state_after": {"caller_name": "John Doe"}}}], "final_state": {"caller_name": "John Doe"}, "expected_dispatch": null}
{"id": "unsafe_input_mid_intake", "description": "Caller cooperates briefly, then slips into narrating after giving their name. Agent must interrupt, then continue intake where it left off.", "tags": ["unsafe_input", "interrupt", "resume"], "turns": [{"caller": "Yes please.", "expect": {"intent": "ask_name", "state_after": {"consent": true}}}, {"caller": "John Doe.", "expect": {"intent": "ask_charge", "state_after": {"caller_name": "John Doe"}}}, {"caller": "I was driving home and I might have had a few too many—", "expect": {"intent": "interrupt_unsafe", "agent_must_include": ["stop you", "recorded", "do not tell me what happened"], "tool_calls": []}}, {"caller": "DUI.", "expect": {"intent": "ask_callback", "state_after": {"charge_category": "DUI"}}}], "final_state": {"consent": true, "caller_name": "John Doe", "charge_category": "DUI"}, "expected_dispatch": null}
{"id": "unsafe_input_repeated", "description": "Caller mixes narrative with routing info on every turn. Agent must interrupt each time without ever acknowledging the narrative substance, and still extract the routing fields embedded in each turn.", "tags": ["unsafe_input", "interrupt", "repeated", "privilege"], "turns": [{"caller": "Yes.", "expect": {"intent": "ask_name", "state_after": {"consent": true}}}, {"caller": "John Doe. Listen, I didn't do it, they're saying I assaulted someone but—", "expect": {"intent": "interrupt_unsafe", "agent_must_include": ["stop you", "recorded"], "agent_must_not_include": ["assault", "didn't do"], "state_after": {"caller_name": "John Doe"}}}, {"caller": "Assault charge. But I really want to explain what happened—", "expect": {"intent": "interrupt_unsafe", "agent_must_include": ["save that for your attorney"], "agent_must_not_include": ["explain"], "state_after": {"charge_category": "assault"}}}, {"caller": "OK. 555-1234567.", "expect": {"intent": "confirm_and_dispatch", "agent_must_include": ["Bay Area", "right to remain silent"], "tool_calls": ["moss_find_lawyers"], "state_after": {"callback_number": "+15551234567"}}}], "final_state": {"consent": true, "caller_name": "John Doe", "charge_category": "assault", "callback_number": "+15551234567"}, "expected_dispatch": {"required": ["moss_find_lawyers"], "any_of": [["contact_attorneys", "email_attorneys"]], "forbidden": []}}
