{
  "$schema": "https://biomejs.dev/schemas/2.4.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**/*.js", "**/*.ts", "**/*.tsx", "**/*.jsx", "**/*.css", "**/*.json"],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": { "noExcessiveCognitiveComplexity": "error" },
      "correctness": { "noUndeclaredVariables": "error", "noUnusedVariables": "error" },
      "style": {
        "useNamingConvention": "off",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error"
      },
      "suspicious": { "noConsole": "off", "noExplicitAny": "error" },
      "security": { "noDangerouslySetInnerHtml": "error" }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "linter": { "enabled": true },
    "formatter": { "enabled": true, "quoteStyle": "double" }
  },
  "json": {
    "linter": { "enabled": true },
    "formatter": { "enabled": true, "indentWidth": 2 }
  }
}
